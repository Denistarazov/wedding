NEXT_PUBLIC_APP_URL=https://weddingbuy.ru

# Neon Postgres / Supabase Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

# Admin owner access
ADMIN_PASSWORD=change-this-long-password
ADMIN_SESSION_SECRET=change-this-random-session-secret

# YooKassa test or production credentials
YOOKASSA_SHOP_ID=000000
YOOKASSA_SECRET_KEY=test_xxxxxxxxxxxxxxxxxxxxx

# Optional analytics IDs if you add external analytics later
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
